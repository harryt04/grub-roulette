# Google Places API — server-side only (no NEXT_PUBLIC_ prefix)
# Required. Used in all three API routes. Never expose to client.
GOOGLE_MAPS_API_KEY=

# PostHog Analytics — public (client + server)
# Required in production. PostHog project API key.
NEXT_PUBLIC_POSTHOG_KEY=

# PostHog ingest host. Defaults to app.posthog.com.
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Canonical URL for sitemap and OG tags.
NEXT_PUBLIC_BASE_URL=https://grub.harryt.dev
