{
  "name": "grub-roulette",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "npx eslint src; prettier --check .",
    "prettify": "prettier --write .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "ciTests": "npx prettier --check . && npx eslint src && npx tsc --noEmit && npm run build && npm run test:unit",
    "fixLint": "prettier --write . && eslint --fix src"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@tailwindcss/postcss": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.359.1",
    "posthog-node": "^4.18.0",
    "react": "^18",
    "react-dom": "^18",
    "react-masonry-css": "^1.0.16",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.9.1",
    "@next/eslint-plugin-next": "^15.5.12",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.9.1",
    "eslint-config-next": "^15.5.12",
    "jsdom": "^29.0.2",
    "prettier": "^3.3.3",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
